<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TyplxKeyboard">

        <!-- IME service -->
        <service
            android:name=".GrammarKeyboardService"
            android:label="@string/ime_name"
            android:permission="android.permission.BIND_INPUT_METHOD"
            android:exported="true">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/method" />
        </service>

        <!-- Settings activity — also launchable from the app drawer for easy first-run setup -->
        <activity
            android:name=".SettingsActivity"
            android:label="@string/settings_title"
            android:exported="true"
            android:theme="@style/Theme.TyplxKeyboard">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".WordListActivity"
            android:label="Personal word list"
            android:exported="false"
            android:theme="@style/Theme.TyplxKeyboard"
            android:parentActivityName=".SettingsActivity" />

    </application>

</manifest>
